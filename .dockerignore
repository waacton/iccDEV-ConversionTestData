# Prevent local build artifacts from breaking Docker builds
# Only exclude generated cmake outputs, not cmake source configuration
Build/Cmake/CMakeCache.txt
Build/Cmake/CMakeFiles/
Build/Cmake/Makefile
Build/Cmake/cmake_install.cmake
# Exclude built libraries and binaries (will be rebuilt in Docker)
Build/Cmake/IccProfLib/*.so*
Build/Cmake/IccProfLib/*.a
Build/Cmake/IccXML/*.so*
Build/Cmake/IccXML/*.a
Build/Cmake/IccJSON/*.so*
Build/Cmake/IccJSON/*.a
.git
