#  Last Updated: 2026-03-24 20:49:38 UTC by David Hoyt
#
# CMake Configuration:
# - PUBLIC target_include_directories for IccProfLib2 and IccXML2
#   (build-dir-first so generated version header with git hash wins)
# - EXPORT RefIccMAXTargets for build-tree and install-tree consumers
# - New FindRefIccMAX.cmake module for standalone find_package()
# - Modern RefIccMAXConfig.cmake.in using target-based imports
# - Tool CMakeLists: target_include_directories(PRIVATE) replaces global
#               
#
###############################################################
# RefIccMAX CMake Config File
# Provides modern IMPORTED targets for ICC color management libraries
#
# Usage:
#   find_package(RefIccMAX CONFIG REQUIRED)
#   target_link_libraries(myapp PRIVATE RefIccMAX::IccProfLib2)
#   target_link_libraries(myapp PRIVATE RefIccMAX::IccXML2)
#
# Namespaced targets (recommended — include dirs propagate automatically):
#   RefIccMAX::IccProfLib2        - Core ICC profile library
#   RefIccMAX::IccXML2            - XML serialization library (links IccProfLib2 transitively)
#   RefIccMAX::IccProfLib2-static - Static version
#   RefIccMAX::IccXML2-static     - Static version
#
# Legacy variables (backward compatibility):
#   REFICCMAX_FOUND        - True if RefIccMAX found
#   REFICCMAX_INCLUDE_DIRS - Include directories
#   REFICCMAX_LIBRARIES    - Libraries to link
#   REFICCMAX_VERSION      - Version string (x.y.z.w)
###############################################################

# Version information
set(REFICCMAX_VERSION_MAJOR @REFICCMAX_MAJOR_VERSION@)
set(REFICCMAX_VERSION_MINOR @REFICCMAX_MINOR_VERSION@)
set(REFICCMAX_VERSION_MICRO @REFICCMAX_MICRO_VERSION@)
set(REFICCMAX_VERSION_PATCH @REFICCMAX_PATCH_VERSION@)
set(REFICCMAX_VERSION @REFICCMAX_VERSION@)

# Load exported targets — this creates RefIccMAX::IccProfLib2, RefIccMAX::IccXML2, etc.
# with all include directories, link dependencies, and compile features pre-configured.
include("${CMAKE_CURRENT_LIST_DIR}/RefIccMAXTargets.cmake")

# IccXML2 requires libxml2 — find it so the transitive dependency resolves
find_package(LibXml2 QUIET)

# Handle find_package() standard args
include(FindPackageHandleStandardArgs)
find_package_handle_standard_args(RefIccMAX
  REQUIRED_VARS CMAKE_CURRENT_LIST_DIR
  VERSION_VAR REFICCMAX_VERSION
)

# Legacy variable support
if(RefIccMAX_FOUND OR REFICCMAX_FOUND)
  set(REFICCMAX_FOUND TRUE)

  # Build legacy include/library lists from the exported targets
  set(REFICCMAX_INCLUDE_DIRS "")
  set(REFICCMAX_LIBRARIES "")

  if(TARGET RefIccMAX::IccProfLib2)
    get_target_property(_proflib_incs RefIccMAX::IccProfLib2 INTERFACE_INCLUDE_DIRECTORIES)
    if(_proflib_incs)
      list(APPEND REFICCMAX_INCLUDE_DIRS ${_proflib_incs})
    endif()
    list(APPEND REFICCMAX_LIBRARIES RefIccMAX::IccProfLib2)
  elseif(TARGET RefIccMAX::IccProfLib2-static)
    get_target_property(_proflib_incs RefIccMAX::IccProfLib2-static INTERFACE_INCLUDE_DIRECTORIES)
    if(_proflib_incs)
      list(APPEND REFICCMAX_INCLUDE_DIRS ${_proflib_incs})
    endif()
    list(APPEND REFICCMAX_LIBRARIES RefIccMAX::IccProfLib2-static)
  endif()

  if(TARGET RefIccMAX::IccXML2)
    list(APPEND REFICCMAX_LIBRARIES RefIccMAX::IccXML2)
  elseif(TARGET RefIccMAX::IccXML2-static)
    list(APPEND REFICCMAX_LIBRARIES RefIccMAX::IccXML2-static)
  endif()

  if(REFICCMAX_INCLUDE_DIRS)
    list(REMOVE_DUPLICATES REFICCMAX_INCLUDE_DIRS)
  endif()

  # Non-namespaced aliases for projects that use bare target names
  if(TARGET RefIccMAX::IccProfLib2 AND NOT TARGET IccProfLib2)
    add_library(IccProfLib2 ALIAS RefIccMAX::IccProfLib2)
  endif()
  if(TARGET RefIccMAX::IccXML2 AND NOT TARGET IccXML2)
    add_library(IccXML2 ALIAS RefIccMAX::IccXML2)
  endif()
  if(TARGET RefIccMAX::IccProfLib2-static AND NOT TARGET IccProfLib2-static)
    add_library(IccProfLib2-static ALIAS RefIccMAX::IccProfLib2-static)
  endif()
  if(TARGET RefIccMAX::IccXML2-static AND NOT TARGET IccXML2-static)
    add_library(IccXML2-static ALIAS RefIccMAX::IccXML2-static)
  endif()
endif()
