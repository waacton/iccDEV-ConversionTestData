{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default-base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "vs2022-x64",
      "inherits": "default-base",
      "displayName": "Windows MSVC (VS2022)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$penv{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_DIR": "${sourceDir}"
      }
    },
    {
      "name": "vs2022-clangcl-x64",
      "inherits": "vs2022-x64",
      "displayName": "Windows ClangCL (VS2022)",
      "toolset": "ClangCL"
    },
    {
      "name": "mingw-ucrt64-base",
      "inherits": "default-base",
      "hidden": true,
      "generator": "Ninja",
      "environment": {
        "PATH": "C:/msys64/ucrt64/bin;C:/msys64/usr/bin;$penv{PATH}"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "C:/msys64/ucrt64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/msys64/ucrt64/bin/g++.exe",
        "CMAKE_PREFIX_PATH": "C:/msys64/ucrt64"
      }
    },
    {
      "name": "mingw-x64",
      "inherits": "mingw-ucrt64-base",
      "displayName": "Windows MinGW UCRT64",
      "cacheVariables": {
        "ENABLE_WXWIDGETS": "OFF",
        "ENABLE_CMM_TOOLS": "OFF",
        "ENABLE_IIS_TOOLS": "OFF"
      }
    },
    {
      "name": "mingw-core-x64",
      "inherits": "mingw-ucrt64-base",
      "displayName": "Windows MinGW UCRT64 core static",
      "cacheVariables": {
        "ENABLE_TESTS": "ON",
        "ENABLE_TOOLS": "ON",
        "ENABLE_STATIC_LIBS": "ON",
        "ENABLE_SHARED_LIBS": "OFF",
        "ENABLE_ICCXML": "OFF",
        "ENABLE_ICCJSON": "ON",
        "ENABLE_IMAGE_TOOLS": "OFF",
        "ENABLE_WXWIDGETS": "OFF",
        "ENABLE_CMM_TOOLS": "OFF",
        "ENABLE_IIS_TOOLS": "OFF"
      }
    },
    {
      "name": "linux-gcc",
      "inherits": "default-base",
      "displayName": "Linux GCC",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "linux-clang",
      "inherits": "default-base",
      "displayName": "Linux Clang",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-gcc-asan",
      "inherits": "linux-gcc",
      "displayName": "Linux GCC with AddressSanitizer",
      "cacheVariables": {
        "ENABLE_ASAN": "ON",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "linux-clang-asan",
      "inherits": "linux-clang",
      "displayName": "Linux Clang with AddressSanitizer",
      "cacheVariables": {
        "ENABLE_ASAN": "ON",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "linux-clang-tsan",
      "inherits": "linux-clang",
      "displayName": "Linux Clang with ThreadSanitizer",
      "cacheVariables": {
        "ENABLE_TSAN": "ON",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "linux-clang-msan",
      "inherits": "linux-clang",
      "displayName": "Linux Clang with MemorySanitizer",
      "cacheVariables": {
        "ENABLE_MSAN": "ON",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "linux-clang-ubsan",
      "inherits": "linux-clang",
      "displayName": "Linux Clang with UBSanitizer",
      "cacheVariables": {
        "ENABLE_UBSAN": "ON",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "linux-raspi",
      "inherits": "default-base",
      "displayName": "Linux Raspberry Pi (GCC, Release, no GUI)",
      "generator": "Unix Makefiles",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "ENABLE_WXWIDGETS": "OFF",
        "ENABLE_CMM_TOOLS": "OFF",
        "ENABLE_IIS_TOOLS": "OFF",
        "ENABLE_LTO": "OFF"
      }
    },
    {
      "name": "linux-raspi-debug",
      "inherits": "linux-raspi",
      "displayName": "Linux Raspberry Pi (GCC, Debug)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "macos-xcode",
      "inherits": "default-base",
      "displayName": "macOS (Xcode)",
      "generator": "Xcode"
    }
  ]
}
